{
  "name": "youtube-popular-search",
  "version": "0.1.1",
  "description": "Chrome extension that adds a time-range dropdown to YouTube's Popular sort.",
  "scripts": {
    "watch": "webpack --config webpack/webpack.dev.js --watch",
    "watch:chrome": "webpack --config webpack/webpack.dev.js --watch",
    "watch:firefox": "webpack --config webpack/webpack.dev.js --watch --env browser=firefox",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "webpack --config webpack/webpack.prod.js",
    "build:firefox": "webpack --config webpack/webpack.prod.js --env browser=firefox",
    "clean": "rimraf dist dist-firefox",
    "version": "node scripts/sync-manifest-version.js && git add public/manifest.json",
    "bump:patch": "npm version patch",
    "bump:minor": "npm version minor",
    "bump:major": "npm version major",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p src/__tests__/tsconfig.json",
    "style": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tom-Caz/youtube-popular-search.git"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.158",
    "@types/react": "^18.0.29",
    "@types/react-dom": "^18.0.11",
    "copy-webpack-plugin": "^14.0.0",
    "glob": "^7.1.6",
    "jsdom": "^29.1.1",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2 ",
    "ts-loader": "^8.0.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.8",
    "webpack": "^5.94.0",
    "webpack-cli": "^4.0.0",
    "webpack-merge": "^5.0.0"
  }
}
