{
  "manifest_version": 3,

  "name": "YouTube Popular Search",
  "description": "Adds a time-range dropdown (Today/Week/Month/Year/All time) to YouTube's Popular sort, like Reddit's sort menu.",
  "version": "0.1.0",

  "options_ui": {
    "page": "options.html"
  },

  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },

  "content_scripts": [
      {
          "matches": ["*://*.youtube.com/*"],
          "js": ["js/vendor.js", "js/content_script.js"],
          "css": ["content_script.css"],
          "run_at": "document_idle"
      }
  ],

  "background": {
    "service_worker": "js/background.js"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "*://*.youtube.com/*",
    "https://www.googleapis.com/*"
  ]
}
